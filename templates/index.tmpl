<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forum</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <header>
        <a class="brand tohover" href="/">Forum name</a>
        <form class="search" action="/" method="GET">
            <input type="text" name="q" placeholder="Rechercher...">
            <button class="tohover" type="submit">OK</button>
        </form>
        <nav class="authNav">
            <a class="tohover" href="register">S'inscrire</a>
            <a class="tohover" href="login">Se connecter</a>
        </nav>
    </header>

    <main class="layout">
        <nav id="sideNav">
            <a class="tohover">Populaires</a>
            <a class="tohover">Categories</a>
            <a class="tohover">Page aleatoire</a>
        </nav>

        <section class="feed">
            {{ range . }}
            <article class="data">
                <h3>
                    <a href="/posts/{{ .ID }}">{{ .Title }}</a>
                </h3>
                <p>{{ .Content }}</p>
                <small>{{ .Author }} - {{ .Category }}</small>
            </article>
            {{ else }}
            <p class="data">Void for now</p>
            {{ end }}
        </section>
    </main>
</body>
</html>
